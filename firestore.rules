rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /** 코드 masterAccounts.ts 와 동일 — Auth 토큰 이메일 */
    function isMasterAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'yoonwhan0@gmail.com';
    }

    function isRoleAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isMasterAdmin() || isRoleAdmin();
    }

    /** Admin 시드 DB 업로드 — userId dreamlab-seed-data */
    function isAdminSeedCreate() {
      return isAdmin()
        && request.resource.data.userId == 'dreamlab-seed-data';
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ai_usage/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /kpi_snapshots/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
      allow list: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );

      match /story_unlocks/{keywordKey} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    match /story_payment_orders/{orderId} {
      allow read, write: if false;
    }

    match /dreams/{dreamId} {
      allow get: if resource.data.isPublic == true
        || (request.auth != null && resource.data.userId == request.auth.uid)
        || isAdmin();
      allow list: if isAdmin()
        || resource.data.isPublic == true
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null
        && (
          request.resource.data.userId == request.auth.uid
          || isAdminSeedCreate()
          || isAdmin()
        );
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
