{
  "name": "dream-after",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-branch-env.mjs && node scripts/inject-firebase-sw.mjs",
    "predev:admin": "node scripts/sync-branch-env.mjs",
    "prebuild": "node scripts/inject-firebase-sw.mjs",
    "dev": "vite",
    "dev:vercel": "vercel dev --listen 3000",
    "dev:netlify": "netlify dev",
    "dev:admin": "vite --config vite.admin.config.ts",
    "build": "npm run icons && tsc --noEmit && vite build",
    "build:admin": "npm run icons && tsc --noEmit && vite build --config vite.admin.config.ts",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "firebase": "^11.6.0",
    "firebase-admin": "^13.2.0",
    "lucide-react": "^1.23.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@netlify/functions": "^3.1.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "netlify-cli": "^23.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "vercel": "^44.0.0",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^0.21.2"
  }
}
